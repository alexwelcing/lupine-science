          <p>The remediation imperative, now with a narrated film and shareable clips.</p>
        </a>
        <a href="/articles/cement-concrete-and-the-weight-of-the-built-world/">
          <img src="/articles/cement-concrete-and-the-weight-of-the-built-world/hero.jpg" alt="" loading="lazy" decoding="async" width="640" height="360">
          <span class="d8">July 16, 2026</span>
          <h3>Cement and Concrete</h3>
          <p>The weight of the built world, made lighter by correction.</p>
        </a>
        <a href="/articles/five-materials-for-5-to-12-gtco2-year/">
          <img src="/articles/five-materials-for-5-to-12-gtco2-year/hero.jpg" alt="" loading="lazy" decoding="async" width="640" height="360">
          <span class="d8">July 16, 2026</span>
          <h3>Five Materials for 5–12 GtCO₂/Year</h3>
          <p>The material bottlenecks that could unlock gigatonne-scale impact.</p>
        </a>
      </div>
      <div class="series-cta">
        <a href="/proof-pack-climate-series.pdf" download>Download the proof pack <span class="ar">→</span></a>
        <a href="/videos/">Watch the films <span class="ar">→</span></a>
        <a href="/articles/">All articles <span class="ar">→</span></a>
      </div>
    </div>

    <div class="b-notebook">
      <p class="b-label">From the notebook</p>
      <div class="b-cards">
        <a href="/articles/the-02-percent-synthesis-problem/">
          <span class="d8">2026·07·09</span>
          <h3>The 0.2% Synthesis Problem</h3>
          <p>Why most computationally predicted materials never reach a synthesis vessel — and why that matters for climate-critical materials.</p>
        </a>
        <a href="/articles/a-field-not-a-neural-net/">
          <span class="d8">2026·07·09</span>
          <h3>A Field, Not a Neural Net</h3>
          <p>The measured error geometry of universal machine-learned interatomic potentials — and the field that tames it.</p>
        </a>
        <a href="/articles/the-trust-layer/">
          <span class="d8">2026·07·05</span>
          <h3>The Trust Layer</h3>
          <p>The founding thesis: science moves at the speed of what it can trust, and we are building the proof infrastructure for designed matter.</p>
        </a>
      </div>
      <p class="b-all"><a href="/articles/">All articles <span class="ar">→</span></a></p>
    </div>
  </section>

  <!-- ════ COLOPHON ════ -->
  <footer class="foot">
    <span class="creed">Unlocking the materials that build the future. <em>Evidence before claim.</em></span>
    <span><b>Lupine Science</b> · founder Alex Welcing · <a class="mail" href="/cdn-cgi/l/email-protection#c0a1aca5b880acb5b0a9aea5b3a3a9eea3afad" data-u="alex" data-d="lupinesci.com">alex [at] lupinesci.com</a></span>
    <span><a href="/articles/">Articles</a> · <a href="https://lupi.live">LUPI</a> · <a href="https://library.lupine.science">Library</a> · <a href="/brand-assets/">Brand assets</a> · <a href="https://github.com/alexwelcing/lupine">Repository</a></span>
    <span class="offer">If you find a claim on this page you cannot check, <a class="mail" href="/cdn-cgi/l/email-protection#10717c7568507c6560797e756373793e737f7d" data-u="alex" data-d="lupinesci.com" data-keep-text>write to us</a> — we treat that as a defect.</span>
    <span class="receipts" id="receipts"></span>
  </footer>

  <div class="tip" id="tip" role="status" aria-live="polite"></div>

  <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
  (() => {
    "use strict";
    const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const body = document.body;

    /* ───────────────────────────────────────────────────────────
       REAL DATA — the manifold is rendered from the committed
       benchmark_manifold.json, computed live in the browser.
       Inline fallback (a subset of that file) guarantees first paint.
       ─────────────────────────────────────────────────────────── */
    const FALLBACK = [
      { potential:"Adams-1989",  eigenvalues:[60.449,22.010,9.238,0],        eigenvectors:[[-0.9571,0.2374,-0.1659,-0.0081,-0.0004]], effective_dimensionality:1.9907, cumulative_variance:[0.6592], log_r_squared:0.9981, is_hyper_ribbon:true },
      { potential:"Foiles-1986", eigenvalues:[83.599,19.398,9.009,0],        eigenvectors:[[-0.8735,0.3298,-0.3580,-0.0062,-0.0004]], effective_dimensionality:1.6848, cumulative_variance:[0.7464], log_r_squared:0.9687, is_hyper_ribbon:true },
      { potential:"Zhou-2004",   eigenvalues:[28.070,1.980,0.125,0.0002,0],  eigenvectors:[[0.7893,0.5647,0.2409,-0.0033,-0.0003]],  effective_dimensionality:1.1499, cumulative_variance:[0.9302], log_r_squared:0.9493, is_hyper_ribbon:true },
      { potential:"Ackland-1987",eigenvalues:[1611.42,390.71,0.176,0],       eigenvectors:[[-0.5589,-0.5853,-0.5874,-0.0003,0]],     effective_dimensionality:1.4583, cumulative_variance:[0.8048], log_r_squared:0.8633, is_hyper_ribbon:true },
    ];
    const DATALINK = "/data/benchmark_manifold.json";

    const hypot = (v) => Math.sqrt(v.reduce((s, x) => s + x * x, 0)) || 1;
    const cosAbs = (a, b) => { let s = 0; const n = Math.min(a.length, b.length); for (let i = 0; i < n; i++) s += a[i] * b[i]; return Math.abs(s / (hypot(a) * hypot(b))); };
    const mean = (a) => a.reduce((s, x) => s + x, 0) / (a.length || 1);

    function process(raw) {
      const pots = raw.map((r) => {
        const eig = (r.eigenvalues || []).filter((e) => e > 1e-9);
        const pc1 = r.eigenvectors[0];
        const thin = eig.length > 1 ? Math.sqrt(eig[1] / eig[0]) : 0.12;
        return { name: r.potential, eig, pc1, pr: r.effective_dimensionality,
                 var1: (r.cumulative_variance && r.cumulative_variance[0]) || 0,
                 r2: r.log_r_squared, ribbon: !!r.is_hyper_ribbon, thin };
      });
      const prs = pots.map((p) => p.pr), pairs = [];
      for (let i = 0; i < pots.length; i++) for (let j = i + 1; j < pots.length; j++) pairs.push(cosAbs(pots[i].pc1, pots[j].pc1));
      return { pots, n: pots.length, prMin: Math.min(...prs), prMax: Math.max(...prs), prMean: mean(prs),
               var1Min: Math.min(...pots.map((p) => p.var1)), var1Max: Math.max(...pots.map((p) => p.var1)),
               meanThin: mean(pots.map((p) => p.thin)), cosMean: mean(pairs), nPairs: pairs.length,
               nRibbon: pots.filter((p) => p.ribbon).length };
    }
    let M = process(FALLBACK);

    function injectProv() {
      const $ = (id) => document.getElementById("prov-" + id);
      const src = `<a href="${DATALINK}">see the data ↗</a>`;
      if ($("objective")) $("objective").innerHTML =
        `live · every figure here is computed in your browser from <b>${M.n}</b> real reference models, not typed in · ${src}`;
      if ($("manifold")) $("manifold").innerHTML =
        `live · measured here: the errors span only <b>${M.prMin.toFixed(1)}–${M.prMax.toFixed(1)}</b> directions, not the thousands possible · ${src}`;
      if ($("errorvectors")) $("errorvectors").innerHTML =
        `live · measured here: the models agree on direction about <b>${Math.round(M.cosMean * 100)}%</b> of the time · ${src}`;
      if ($("ledger")) $("ledger").innerHTML =
        `live · the same pattern holds in all <b>${M.nRibbon}/${M.n}</b> reference models, re-checked in your browser · ${src}`;
    }
    injectProv();
    // freshen from the served file (same data, proves the wiring is real)
    fetch(DATALINK)
      .then((r) => (r.ok ? r.json() : Promise.reject()))
      .then((raw) => { if (Array.isArray(raw) && raw.length) { M = process(raw); injectProv(); } })
      .catch(() => {});

    /* ───────────────────────────────────────────────────────────
       REAL MATTER — one cavity of MOF-5 (Zn₄O(BDC)₃), from the committed
       crystal structure (COD 1516287; Yaghi et al., Nature 402, 276).
       The canvas renders these coordinates directly: published atoms,
       not an artist's impression.
       ─────────────────────────────────────────────────────────── */
    const MATTERLINK = "/data/mof5_structure.json";
    let MOF = null;             // { els, pos, bonds, rmax, zn: [indices] }
    let onMatterReady = () => {};
    fetch(MATTERLINK)
      .then((r) => (r.ok ? r.json() : Promise.reject()))
      .then((raw) => {
        // hydrogens are omitted from the drawing, as in standard MOF renders
        const keep = [];
        raw.elements.forEach((el, i) => { if (el !== "H") keep.push(i); });
        const remap = new Map(keep.map((old, now) => [old, now]));
        const els = keep.map((i) => raw.elements[i]);
        const pos = keep.map((i) => raw.positions[i]);
        const bonds = raw.bonds
          .filter(([a, b]) => remap.has(a) && remap.has(b))
          .map(([a, b]) => [remap.get(a), remap.get(b)]);
        let rmax = 0;
        for (const p of pos) rmax = Math.max(rmax, Math.hypot(p[0], p[1], p[2]));
        const zn = [];
        els.forEach((el, i) => { if (el === "Zn") zn.push(i); });
        MOF = { els, pos, bonds, rmax, zn, proj: new Array(pos.length) };
        onMatterReady();
      })
      .catch(() => {});

    /* per-term targets for the manifold + the resolved panel */
    const FOCUS = {
      objective:    { converge: 0.55, ribbon: 0.92, vector: 0.5,  ledger: 0.35, ochre: 0.0, spectrum: 0.2,  fan: 0.2,  matter: 0.92 },
      manifold:     { converge: 0.96, ribbon: 1.0,  vector: 0.16, ledger: 0.22, ochre: 0.0, spectrum: 1.0,  fan: 0.10, matter: 0.2  },
      errorvectors: { converge: 0.40, ribbon: 0.5,  vector: 1.0,  ledger: 0.18, ochre: 0.0, spectrum: 0.12, fan: 1.0,  matter: 0.34 },
      ledger:       { converge: 0.7,  ribbon: 0.82, vector: 0.28, ledger: 1.0,  ochre: 1.0, spectrum: 0.18, fan: 0.12, matter: 0.55 },
    };
    const cur = { ...FOCUS.objective };
    let tgt = { ...FOCUS.objective };
    let recomputeZones = () => {};   // assigned by the renderer; keeps the mask in sync

    function setFocus(name) {
      if (!FOCUS[name]) name = "objective";
      tgt = { ...FOCUS[name] };
      body.setAttribute("data-focus", name);
      document.querySelectorAll("button.term, .legend button").forEach((b) =>
        b.setAttribute("aria-pressed", String(b.dataset.focus === name)));
      document.querySelectorAll(".panel").forEach((p) => {
        if (p.dataset.panel === name) p.setAttribute("data-active", "");
        else p.removeAttribute("data-active");
      });
      // the active evidence panel changes height → re-measure the type zones
      requestAnimationFrame(() => recomputeZones());
    }

    /* tooltip */
    const tip = document.getElementById("tip");
    function bindTip(el) {
      const show = (x, y) => { tip.innerHTML = el.dataset.tip || ""; tip.classList.add("show"); place(x, y); };
      const place = (x, y) => {
        const pad = 14, r = tip.getBoundingClientRect();
        let nx = x + 16, ny = y + 18;
        if (nx + r.width + pad > innerWidth) nx = innerWidth - r.width - pad;
        if (ny + r.height + pad > innerHeight) ny = y - r.height - 18;
        tip.style.left = nx + "px"; tip.style.top = Math.max(pad, ny) + "px";
      };
      el.addEventListener("pointerenter", (e) => show(e.clientX, e.clientY));
      el.addEventListener("pointermove", (e) => place(e.clientX, e.clientY));
      el.addEventListener("focus", () => { const r = el.getBoundingClientRect(); show(r.left, r.bottom); });
      el.addEventListener("pointerleave", () => tip.classList.remove("show"));
      el.addEventListener("blur", () => tip.classList.remove("show"));
    }
    // tooltips are a hover affordance: on touch devices a tap would pin
    // them open over the equation and legend, so bind only where hover exists
    if (matchMedia("(hover: hover) and (pointer: fine)").matches) {
      document.querySelectorAll(".term").forEach(bindTip);
    }

    document.querySelectorAll(".term, .legend button").forEach((b) => {
      b.addEventListener("click", () => {
        const n = b.dataset.focus;
        const current = body.getAttribute("data-focus");
        setFocus(current === n && n !== "objective" ? "objective" : n);
      });
    });
    addEventListener("keydown", (e) => { if (e.key === "Escape") setFocus("objective"); });

    /* ── the manifold renderer ── */
    const canvas = document.getElementById("ribbon");
    const ctx = canvas && canvas.getContext ? canvas.getContext("2d") : null;
    if (!ctx) {
      body.classList.add("no-canvas");
      const fb = document.querySelector(".ribbon-fallback[data-src]");
      if (fb) fb.src = fb.dataset.src;
    }
    else {
      const INK = "22,23,29", IND = "61,77,179", OCH = "168,119,43";
      let w = 0, h = 0, dpr = 1, raf = 0, t0 = 0, pts = [];

      function seed() {
        const n = Math.max(60, Math.min(190, Math.round((w * h) / 9000)));
        pts = [];
        for (let i = 0; i < n; i++) {
          const r1 = frac(Math.sin(i * 12.9898) * 43758.5453);
          const r2 = frac(Math.sin(i * 78.233) * 12543.123);
          const r3 = frac(Math.sin(i * 39.425) * 9123.77);
          // bias samples toward the right/centre so the lower-left reading zone stays calm
          const u = 0.32 + r1 * 0.72;
          // every third sample is "corrected": it settles onto a real lattice site
          pts.push({ u: Math.min(u, 1), sy: (r2 - 0.5), ph: r3 * 6.283, sp: 0.4 + r3 * 0.9, pot: i % M.n,
                     site: i % 3 === 0 ? (i * 7) % 97 : -1 });
        }
      }
      const frac = (x) => x - Math.floor(x);
      const clamp01 = (x) => (x < 0 ? 0 : x > 1 ? 1 : x);

      /* ── layout-aware mask: the manifold parts around the type zones so no
         object ever sits on top of text. Computed from the live DOM rects. ── */
      let zones = [], STAGE = { x0: 0, x1: 0, y0: 0, y1: 0, cx: 0, cy: 0, w: 0, h: 0 };
      const FEATHER = 36;
      const mobileMQ = matchMedia("(max-width: 920px)");
      function rectOf(sel) {
        const el = document.querySelector(sel); if (!el) return null;
        const b = el.getBoundingClientRect(), c = canvas.getBoundingClientRect();
        if (b.width < 1 || b.height < 1) return null;
        return { l: b.left - c.left, t: b.top - c.top, r: b.right - c.left, bo: b.bottom - c.top };
      }
      function computeZones() {
        zones = [];
        if (mobileMQ.matches) {
          const m = rectOf(".mark"); if (m) zones.push(m);
          STAGE = { x0: w * 0.04, x1: w * 0.96, y0: h * 0.15, y1: h * 0.97 };
        } else {
          [".horizon", ".legend", ".reading .panel[data-active]", ".rail-ledger"]
            .forEach((s) => { const z = rectOf(s); if (z) zones.push(z); });
          const m = rectOf(".mark"); if (m) zones.push({ l: m.l, t: m.t, r: Math.min(m.r, m.l + 250), bo: m.bo });
          const rd = rectOf(".reading .panel[data-active]") || rectOf(".reading");
          const rl = rectOf(".rail-ledger"), lg = rectOf(".legend");
          STAGE = { x0: (rd ? rd.r : w * 0.34) + 28, x1: (rl ? rl.l : w * 0.95) - 28,
                    y0: (lg ? lg.bo : h * 0.26) + 30, y1: h * 0.94 };
        }
        STAGE.cx = (STAGE.x0 + STAGE.x1) / 2; STAGE.cy = (STAGE.y0 + STAGE.y1) / 2;
        STAGE.w = STAGE.x1 - STAGE.x0; STAGE.h = STAGE.y1 - STAGE.y0;
      }
      recomputeZones = computeZones;
      // 1 inside a clear area, ramps to 0 inside any type zone (feathered)
      function clearAt(x, y) {
        let f = 1;
        for (let i = 0; i < zones.length; i++) {
          const z = zones[i];
          const dx = Math.max(z.l - x, 0, x - z.r), dy = Math.max(z.t - y, 0, y - z.bo);
          if (dx === 0 && dy === 0) return 0;
          const d = Math.sqrt(dx * dx + dy * dy);
          if (d < FEATHER) { const k = d / FEATHER; if (k < f) f = k; }
        }
        return f;
      }
      // soft paper halo, so a focal glyph reads on its own ground
      function scrim(cx, cy, r, alpha) {
        if (alpha < 0.02) return;
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
        g.addColorStop(0, `rgba(250,249,246,${0.94 * alpha})`);
        g.addColorStop(0.62, `rgba(250,249,246,${0.55 * alpha})`);
        g.addColorStop(1, "rgba(250,249,246,0)");
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(cx, cy, r, 0, 6.2832); ctx.fill();
      }
      // a soft particle with a fading trail (no arrowhead) — subatomic, not a quiver vector
      function comet(x, y, ang, len, alpha, rgb) {
        rgb = rgb || "61,77,179";
        const hx = x + Math.cos(ang) * len, hy = y + Math.sin(ang) * len;
        const g = ctx.createLinearGradient(x, y, hx, hy);
        g.addColorStop(0, `rgba(${rgb},0)`); g.addColorStop(1, `rgba(${rgb},${alpha})`);
        ctx.strokeStyle = g; ctx.lineWidth = 1.3; ctx.lineCap = "round";
        ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(hx, hy); ctx.stroke();
        const hg = ctx.createRadialGradient(hx, hy, 0, hx, hy, 4.5);
        hg.addColorStop(0, `rgba(${rgb},${alpha * 1.1})`); hg.addColorStop(1, `rgba(${rgb},0)`);
        ctx.fillStyle = hg; ctx.beginPath(); ctx.arc(hx, hy, 4.5, 0, 6.2832); ctx.fill();
      }

      function resize() {
        dpr = Math.min(devicePixelRatio || 1, 2);
        w = canvas.clientWidth; h = canvas.clientHeight;
        canvas.width = Math.round(w * dpr); canvas.height = Math.round(h * dpr);
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0); seed(); computeZones();
      }
      // ribbon spine biased to the upper-right of the field
      function spineY(u, time, amp) {
        const cy = h * 0.42;
        return cy + Math.sin(u * 3.0 + time * 0.16) * amp + Math.sin(u * 6.1 - time * 0.1) * amp * 0.32;
      }
      function slope(u, time, amp) {
        const e = 0.004;
        return (spineY(u + e, time, amp) - spineY(u - e, time, amp)) / (e * 2 * w);
      }
      function arrow(x, y, ang, len, col, lw) {
        const ex = x + Math.cos(ang) * len, ey = y + Math.sin(ang) * len;
        ctx.strokeStyle = col; ctx.lineWidth = lw;
        ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(ex, ey);
        const a = 0.45, hl = Math.min(4, len * 0.34);
        ctx.lineTo(ex - Math.cos(ang - a) * hl, ey - Math.sin(ang - a) * hl);
        ctx.moveTo(ex, ey); ctx.lineTo(ex - Math.cos(ang + a) * hl, ey - Math.sin(ang + a) * hl);
        ctx.stroke();
      }

      // real eigenvalue spectrum, rendered as an ORBITAL ATOM: nucleus + elliptical
      // shells + orbiting electrons, each shell's weight = its real variance share.
      // The dominant eigenvalue → one bright tight shell = the collapse, made atomic.
      function drawShells(time) {
        if (cur.spectrum < 0.03 || !M.pots.length) return;
        const pot = M.pots[Math.floor(time * 0.14) % M.n];
        const eig = pot.eig.slice().sort((p, q) => q - p); if (eig.length < 2) return;
        const cx = STAGE.cx, cy = STAGE.y0 + STAGE.h * 0.6;
        const a = cur.spectrum * clearAt(cx, cy); if (a < 0.03) return;
        const Rmax = Math.min(STAGE.h * 0.3, STAGE.w * 0.32, 122);
        scrim(cx, cy, Rmax * 1.45, cur.spectrum);
        const total = eig.reduce((s, e) => s + e, 0) || 1, n = eig.length;
        // nucleus glow
        const ng = ctx.createRadialGradient(cx, cy, 0, cx, cy, 12);
        ng.addColorStop(0, `rgba(${IND},${0.45 * a})`); ng.addColorStop(1, `rgba(${IND},0)`);
        ctx.fillStyle = ng; ctx.beginPath(); ctx.arc(cx, cy, 12, 0, 6.2832); ctx.fill();
        ctx.fillStyle = `rgba(${IND},${0.7 * a})`; ctx.beginPath(); ctx.arc(cx, cy, 2.3, 0, 6.2832); ctx.fill();
        for (let i = 0; i < n; i++) {
          const share = eig[i] / total;                 // real variance fraction
          const r = Rmax * ((i + 1) / n);
          const rot = i * 0.7 + time * 0.05;
          const ringA = a * (0.07 + 0.5 * share);
          ctx.strokeStyle = `rgba(${IND},${ringA})`; ctx.lineWidth = 1;
          ctx.beginPath(); ctx.ellipse(cx, cy, r, r * 0.4, rot, 0, 6.2832); ctx.stroke();
          // electron riding the shell (inner shells faster)
          const ang = time * (0.5 + 1.1 / (i + 1)) + i * 1.7;
          const ex = cx + Math.cos(ang) * r * Math.cos(rot) - Math.sin(ang) * r * 0.4 * Math.sin(rot);
          const ey = cy + Math.cos(ang) * r * Math.sin(rot) + Math.sin(ang) * r * 0.4 * Math.cos(rot);
          const eg = ctx.createRadialGradient(ex, ey, 0, ex, ey, 5.5);
          eg.addColorStop(0, `rgba(${IND},${a * (0.3 + 0.6 * share)})`); eg.addColorStop(1, `rgba(${IND},0)`);
          ctx.fillStyle = eg; ctx.beginPath(); ctx.arc(ex, ey, 5.5, 0, 6.2832); ctx.fill();
          ctx.fillStyle = `rgba(${IND},${a * (0.4 + 0.5 * share)})`; ctx.beginPath(); ctx.arc(ex, ey, 1.4, 0, 6.2832); ctx.fill();
        }
      }

      // real PC1 cosine fan — each potential's first error direction, by its
      // true angular deviation from the reference; tight cluster = alignment
      // real PC1 alignment, rendered as ALIGNED DRIFTING PARTICLES — each potential's
      // first error direction is a comet whose angle is its true deviation from the
      // reference; a tight, near-parallel stream = the "same direction" result.
      function drawAlignment(time) {
        if (cur.fan < 0.03 || M.pots.length < 2) return;
        const cx = STAGE.x0 + STAGE.w * 0.28, cy = STAGE.y0 + STAGE.h * 0.34;
        const L = Math.min(STAGE.w * 0.5, 156);
        const a = cur.fan * clearAt(cx + L * 0.4, cy); if (a < 0.03) return;
        scrim(cx + L * 0.42, cy, L * 0.85, cur.fan);
        const ref = M.pots[0].pc1; let mx = 0, my = 0;
        M.pots.forEach((p, i) => {
          const c = Math.min(1, cosAbs(p.pc1, ref));
          const dev = Math.acos(c) * (i % 2 ? 1 : -1);
          mx += Math.cos(dev); my += Math.sin(dev);
          // a short train of particles per direction → a flowing, near-parallel stream
          for (let k = 0; k < 3; k++) {
            const drift = ((time * 0.16 + i * 0.29 + k * 0.34) % 1);
            const bx = cx + Math.cos(dev) * L * drift, by = cy + Math.sin(dev) * L * drift + (i - 1.5) * 5;
            const fade = Math.sin(drift * Math.PI);          // born → travel → fade
            comet(bx, by, dev, 20 + 14 * (1 - drift), a * (0.34 + 0.4 * c) * (0.3 + 0.7 * fade), IND);
          }
        });
        comet(cx, cy, Math.atan2(my, mx), L * 0.82, a * 0.6, OCH);   // consensus direction
      }

      /* ── real matter: the MOF-5 cavity, drawn from published coordinates ──
         Orthographic projection of the committed structure, slowly turning.
         Zn nodes in deep indigo, carboxylate O in ochre, C in ink — the same
         dialect as the rest of the instrument. The projected Zn positions
         are kept so converging error-particles can land on real lattice
         sites: the math correcting real matter, literally. */
      let latticeXY = [];
      function drawMatter(time) {
        latticeXY.length = 0;
        if (!MOF || cur.matter < 0.03) return;
        const cx = STAGE.cx + STAGE.w * 0.02;
        const cy = STAGE.y0 + STAGE.h * (mobileMQ.matches ? 0.5 : 0.4);
        const R = Math.min(STAGE.w, STAGE.h) * (mobileMQ.matches ? 0.38 : 0.37);
        const A = cur.matter * clearAt(cx, cy);
        if (A < 0.03 || R < 40) return;
        const s = R / MOF.rmax;
        const ry = time * 0.11, rx = -0.42;                 // slow turn, gentle tilt
        const cyr = Math.cos(ry), syr = Math.sin(ry), cxr = Math.cos(rx), sxr = Math.sin(rx);
        const breath = 1 + 0.012 * Math.sin(time * 0.5);
        scrim(cx, cy, R * 1.5, cur.matter * 0.8);
        // project all atoms
        const P = MOF.proj;
        for (let i = 0; i < MOF.pos.length; i++) {
          const p = MOF.pos[i];
          const x1 = p[0] * cyr + p[2] * syr;
          const z1 = -p[0] * syr + p[2] * cyr;
          const y1 = p[1] * cxr - z1 * sxr;
          const z2 = p[1] * sxr + z1 * cxr;
          P[i] = [cx + x1 * s * breath, cy + y1 * s * breath, z2 / MOF.rmax]; // z in [-1,1]
        }
        // bonds, painter's order, depth-cued
        const order = MOF.bonds.map((b, i) => [i, (P[b[0]][2] + P[b[1]][2]) / 2]).sort((a, b) => a[1] - b[1]);
        ctx.lineCap = "round";
        for (const [bi, z] of order) {
          const [i, j] = MOF.bonds[bi];
          const d = (z + 1) / 2;                             // 0 far → 1 near
          const m = Math.min(clearAt(P[i][0], P[i][1]), clearAt(P[j][0], P[j][1]));
          if (m <= 0.02) continue;
          ctx.strokeStyle = `rgba(${INK},${A * m * (0.13 + 0.34 * d)})`;
          ctx.lineWidth = 0.8 + 0.7 * d;
          ctx.beginPath(); ctx.moveTo(P[i][0], P[i][1]); ctx.lineTo(P[j][0], P[j][1]); ctx.stroke();
        }
        // atoms, far to near
        const aorder = P.map((p, i) => [i, p[2]]).sort((a, b) => a[1] - b[1]);
        for (const [i, z] of aorder) {
          const d = (z + 1) / 2;
          const m = clearAt(P[i][0], P[i][1]); if (m <= 0.02) continue;
          const el = MOF.els[i];
          const rgb = el === "Zn" ? "46,58,135" : el === "O" ? OCH : INK;
          const r = (el === "Zn" ? 3.1 : el === "O" ? 2.0 : 1.45) * (0.62 + 0.5 * d);
          const a = A * m * (0.30 + 0.62 * d);
          if (el === "Zn") {                                 // metal nodes glow like the focal bloom
            const g = ctx.createRadialGradient(P[i][0], P[i][1], 0, P[i][0], P[i][1], r * 3.4);
            g.addColorStop(0, `rgba(${IND},${a * 0.5})`); g.addColorStop(1, `rgba(${IND},0)`);
            ctx.fillStyle = g; ctx.beginPath(); ctx.arc(P[i][0], P[i][1], r * 3.4, 0, 6.2832); ctx.fill();
            if (z > -0.1) latticeXY.push([P[i][0], P[i][1]]);
          }
          ctx.fillStyle = `rgba(${rgb},${a})`;
          ctx.beginPath(); ctx.arc(P[i][0], P[i][1], r, 0, 6.2832); ctx.fill();
        }
      }

      let lastPaint = 0;
      function frame(ts) {
        // Keep the ambient canvas below the browser's interaction budget.
        // The drawing is intentionally slow-moving, so 30 fps is visually
        // equivalent while leaving alternate frames free for input work.
        if (lastPaint && ts - lastPaint < 32) {
          raf = requestAnimationFrame(frame);
          return;
        }
        lastPaint = ts;
        if (!t0) t0 = ts; const time = (ts - t0) / 1000;
        for (const k in cur) cur[k] += (tgt[k] - cur[k]) * 0.045;
        ctx.clearRect(0, 0, w, h);
        const amp = h * (0.16 + 0.07 * cur.ribbon);
        // ribbon thickness derives from the REAL mean eigenvalue ratio √(λ₂/λ₁)
        const bandW = h * (0.05 + 0.34 * M.meanThin);
        // slow, ambient breath so the ribbon never reads as a frozen image
        const breath = 0.88 + 0.12 * Math.sin(time * 0.55);

        // ── the hyper-ribbon: the luminous hero motif ──
        // (a) focal bloom — the single indigo light source, seated in the clear window
        {
          const fx = STAGE.cx, fy = spineY(clamp01(STAGE.cx / w), time, amp);
          const R = Math.min(w, h) * 0.34;
          const bg = ctx.createRadialGradient(fx, fy, 0, fx, fy, R);
          bg.addColorStop(0, `rgba(${IND},${0.09 * cur.ribbon * breath})`);
          bg.addColorStop(0.55, `rgba(${IND},${0.035 * cur.ribbon * breath})`);
          bg.addColorStop(1, `rgba(${IND},0)`);
          ctx.fillStyle = bg; ctx.beginPath(); ctx.arc(fx, fy, R, 0, 6.2832); ctx.fill();
        }
        // (b) fine parallel curves — the "many wrong simulations" texture
        const bands = 26;
        for (let b = -bands; b <= bands; b++) {
          const env = 1 - Math.abs(b / bands);
          const off = (b / bands) * bandW;
          ctx.strokeStyle = `rgba(${IND},${(0.04 + env * 0.17 * cur.ribbon * breath)})`;
          ctx.lineWidth = 0.7; ctx.beginPath();
          for (let s = 0; s <= 96; s++) {
            const u = s / 96, x = u * w, y = spineY(u, time, amp) + off * (0.5 + 0.5 * env);
            s === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
          }
          ctx.stroke();
        }
        // (c) luminous core thread — emerges from behind the hero text, dissolves toward the rail
        ctx.save();
        ctx.shadowColor = `rgba(${IND},${0.55 * cur.ribbon * breath})`; ctx.shadowBlur = 9;
        const a0 = STAGE.x0 / w, a1 = STAGE.x1 / w;
        const cg = ctx.createLinearGradient(0, 0, w, 0);
        cg.addColorStop(clamp01(a0 - 0.05), `rgba(${IND},0)`);
        cg.addColorStop(clamp01(a0 + 0.07), `rgba(${IND},${0.34 * cur.ribbon * breath})`);
        cg.addColorStop(clamp01(a1 - 0.03), `rgba(${IND},${0.26 * cur.ribbon * breath})`);
        cg.addColorStop(clamp01(a1 + 0.06), `rgba(${IND},0)`);
        ctx.strokeStyle = cg; ctx.lineWidth = 1.4; ctx.lineCap = "round"; ctx.beginPath();
        for (let s = 0; s <= 110; s++) { const u = s / 110, x = u * w, y = spineY(u, time, amp); s === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); }
        ctx.stroke(); ctx.restore();

        drawMatter(time);

        // scattered error samples collapsing onto the spine, with vectors.
        // converged band-thickness per sample = its potential's real √(λ₂/λ₁)
        for (const p of pts) {
          const pot = M.pots[p.pot % M.n] || { thin: 0.3 };
          let x = p.u * w, ribY = spineY(p.u, time, amp);
          const wide = p.sy * h * 0.46;
          const spread = wide * (1 + (pot.thin - 1) * cur.converge);
          let y = ribY + spread + Math.sin(time * p.sp + p.ph) * h * 0.06 * (1 - 0.55 * cur.converge);
          // a share of the corrected samples settle onto real Zn lattice sites
          if (p.site >= 0 && latticeXY.length) {
            const t2 = latticeXY[p.site % latticeXY.length];
            const k = cur.matter * (0.55 + 0.45 * Math.sin(time * 0.4 + p.ph) ** 2) * 0.8;
            x += (t2[0] - x) * k; y += (t2[1] - y) * k;
          }
          const cm = clearAt(x, y); if (cm <= 0.02) continue;   // never sit on text
          const aligned = Math.atan2(slope(p.u, time, amp) * w, w);
          const ang = p.ph + (aligned - p.ph) * Math.max(cur.converge, cur.vector);
          const len = 7 + 7 * p.sp, core = 1 - Math.abs(p.sy);
          // soft motion trail (no arrowhead)
          ctx.strokeStyle = `rgba(${IND},${(0.12 + 0.46 * cur.vector) * (0.4 + 0.6 * core) * cm})`;
          ctx.lineWidth = 1.0; ctx.lineCap = "round";
          ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(x + Math.cos(ang) * len, y + Math.sin(ang) * len); ctx.stroke();
          // electron: faint halo + core
          ctx.fillStyle = `rgba(${IND},${0.08 * cm})`;
          ctx.beginPath(); ctx.arc(x, y, 2.6 + 1.7 * core, 0, 6.2832); ctx.fill();
          ctx.fillStyle = `rgba(${INK},${(0.14 + 0.14 * (1 - cur.converge)) * cm})`;
          ctx.beginPath(); ctx.arc(x, y, 1.0 + 0.95 * core, 0, 6.2832); ctx.fill();
        }

        drawShells(time);
        drawAlignment(time);

        // ledger — ochre particles condensing along the ribbon (live state)
        if (cur.ledger > 0.02) {
          for (let i = 0; i < 30; i++) {
            const u = (i + 0.5) / 30, x = u * w;
            const y = spineY(u, time, amp) - bandW - 6 + Math.sin(time * 0.9 + i * 1.3) * 3;
            const cm = clearAt(x, y); if (cm <= 0.02) continue;
            const blink = 0.3 + 0.7 * (0.5 + 0.5 * Math.sin(time * 1.6 + i));
            const al = cur.ledger * 0.55 * blink * cm;
            ctx.fillStyle = `rgba(${OCH},${0.18 * al})`;
            ctx.beginPath(); ctx.arc(x, y, 3, 0, 6.2832); ctx.fill();
            ctx.fillStyle = `rgba(${OCH},${al})`;
            ctx.beginPath(); ctx.arc(x, y, 1.3, 0, 6.2832); ctx.fill();
          }
        }
        raf = requestAnimationFrame(frame);
      }

      resize(); addEventListener("resize", resize, { passive: true });
      // when the structure arrives after the reduced-motion single frame,
      // draw one more so the crystal appears in the still image too
      const staticCanvas = reduced || mobileMQ.matches;
      onMatterReady = () => {
        if (staticCanvas) { t0 = 0; requestAnimationFrame((ts) => { frame(ts); cancelAnimationFrame(raf); }); }
      };
      if (staticCanvas) { requestAnimationFrame((ts) => { for (const k in cur) cur[k] = tgt[k]; frame(ts); cancelAnimationFrame(raf); }); }
      else {
        raf = requestAnimationFrame(frame);
        document.addEventListener("visibilitychange", () => {
          if (document.hidden) cancelAnimationFrame(raf); else { t0 = 0; raf = requestAnimationFrame(frame); }
        });
      }
    }

    /* ── public ledger: live commits from the open repository ── */
    (() => {
      const LEDGER_REPO = "alexwelcing/lupine";
      const list = document.getElementById("ledger-list");
      const heightEl = document.getElementById("ledger-height");
      const fallback = [
        { sha: "9b37d99", date: "06·19", msg: "Refactor LUPI viewer loading seams" },
        { sha: "25482ab", date: "06·18", msg: "Retire monorepo LUPI viewer deploy" },
        { sha: "08fe80c", date: "06·17", msg: "Add social cards for saved views" },
        { sha: "109c116", date: "06·17", msg: "Add LUPI analytics measurement tools" },
      ];
      function render(rows) {
        if (!list) return;
        // exactly as many rows as the pre-rendered fallback: the live swap
        // must never change the rail's height — content stays under the
        // ledger's min-height floor, so layout cannot shift
        list.innerHTML = rows.slice(0, 4).map((r) =>
          `<li><span class="hash">${r.sha}</span> <span class="when">${r.date}</span><span class="msg">${r.msg.replace(/</g, "&lt;")}</span></li>`
        ).join("");
      }
      function fmtDate(iso) {
        const d = new Date(iso);
        const m = String(d.getUTCMonth() + 1).padStart(2, "0");
        const day = String(d.getUTCDate()).padStart(2, "0");
        return `${m}·${day}`;
      }
      function parseLastPage(link) {
        if (!link) return null;
        const m = link.match(/page=(\d+)[^>]*>;\s*rel="last"/);
        return m ? parseInt(m[1], 10) : null;
      }
      // start with the previous hardcoded entries so the rail is never empty
      render(fallback);
      // memoize the ledger for 10 minutes: instant repeat views, and kind
      // to GitHub's unauthenticated rate limit
      const MEMO_KEY = "lupine-ledger-v1";
      let memo = null;
      try { memo = JSON.parse(sessionStorage.getItem(MEMO_KEY) || "null"); } catch {}
      if (memo && Date.now() - memo.at < 600000) {
        if (heightEl && memo.total) heightEl.textContent = memo.total;
        render(memo.rows);
      } else {
        fetch(`https://api.github.com/repos/${LEDGER_REPO}/commits?sha=main&per_page=5`, {
          headers: { Accept: "application/vnd.github+json" },
        })
          .then((r) => {
            if (!r.ok) throw new Error(String(r.status));
            const link = r.headers.get("link") || "";
            const total = parseLastPage(link);
            if (heightEl && total) heightEl.textContent = total;
            return r.json().then((commits) => ({ commits, total }));
          })
          .then(({ commits, total }) => {
            if (!Array.isArray(commits) || !commits.length) throw new Error("empty");
            const rows = commits.map((c) => ({
              sha: String(c.sha || "").slice(0, 7),
              date: fmtDate(c.commit && c.commit.committer ? c.commit.committer.date : c.commit.commit_date || ""),
              msg: String(c.commit && c.commit.message ? c.commit.message.split("\n")[0] : ""),
            }));
            render(rows);
            try { sessionStorage.setItem(MEMO_KEY, JSON.stringify({ at: Date.now(), total, rows })); } catch {}
          })
          .catch(() => { /* fallback already visible */ });
      }
    })();

    /* ── the founder's email, assembled here so nothing in the HTML source
       matches an email pattern: proxies that "protect" addresses by
       rewriting them (and then need a script our CSP rightly blocks)
       have nothing to find. JS-off visitors see the [at] spelling. ── */
    document.querySelectorAll("a.mail").forEach((a) => {
      const addr = `${a.dataset.u}@${a.dataset.d}`;
      a.href = `mailto:${addr}`;
      if (!("keepText" in a.dataset)) a.textContent = addr;
    });

    /* ── receipts: this page, measured by the visitor's own browser.
       The same ethos as the benchmark figures above: nothing typed in. ── */
    (() => {
      const el = document.getElementById("receipts");
      if (!el || typeof performance === "undefined" || !performance.getEntriesByType) return;
      setTimeout(() => {
        try {
          const nav = performance.getEntriesByType("navigation")[0];
          if (!nav) return;
          let bytes = nav.transferSize || 0;
          for (const r of performance.getEntriesByType("resource")) bytes += r.transferSize || 0;
          const paint = performance.getEntriesByType("paint").find((p) => p.name === "first-contentful-paint");
          const fp = paint ? ` · first paint ${(paint.startTime / 1000).toFixed(2)} s` : "";
          el.innerHTML = nav.transferSize === 0
            ? `this visit · served from your cache · <b>0 KB</b> over the wire · measured by your browser, not claimed by ours`
            : `this visit · <b>${Math.round(bytes / 1024)} KB</b> over the wire · no framework, no tracker${fp} · measured by your browser, not claimed by ours`;
        } catch { /* the line simply doesn't render */ }
      }, 1400);
    })();

    setFocus("objective");

    // after first paint, enable panel transitions so later focus changes still feel smooth
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const reading = document.querySelector(".reading");
        if (reading) reading.classList.add("is-settled");
      });
    });
  })();
  </script>
</body>
</html>
