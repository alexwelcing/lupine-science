{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FAL Enrich Episode Manifest",
  "type": "object",
  "required": ["slug", "script", "voice", "scenes"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe episode identifier."
    },
    "script": {
      "type": "string",
      "description": "Path to the approved narration script/markdown file."
    },
    "voice": {
      "type": "object",
      "required": ["endpoint", "voice"],
      "properties": {
        "endpoint": {
          "type": "string",
          "default": "fal-ai/elevenlabs/tts/turbo-v2.5"
        },
        "voice": {
          "type": "string",
          "description": "ElevenLabs voice name, e.g. Jessica."
        },
        "speed": {
          "type": "number",
          "minimum": 0.7,
          "maximum": 1.2,
          "default": 1.0
        },
        "seed": {
          "type": ["integer", "null"],
          "default": null
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "start", "duration", "narration", "visual"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "duration": {
            "type": "number",
            "minimum": 0
          },
          "narration": {
            "type": "string"
          },
          "visual": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["image", "chart", "video", "component"]
              },
              "endpoint": {
                "type": "string"
              },
              "prompt": {
                "type": "string"
              },
              "size": {
                "type": "string",
                "default": "landscape_16_9"
              },
              "seed": {
                "type": ["integer", "null"]
              },
              "source": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
